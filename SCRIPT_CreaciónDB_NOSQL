            "properties": {
                "_id": { "bsonType": "objectId" },
                "proyectoId": { "bsonType": "objectId" },
                "tipoIndicador": { "bsonType": "string" },
                "valorMeasured": { "bsonType": "number" },
                "fecha_registro": { "bsonType": "date" }
            },
            "additionalProperties": false
        }
    }
});

